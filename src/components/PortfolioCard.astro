---
interface Props {
  title: string;
  description: string;
  category: string;
  thumbnail: string;
  slug: string;
  featured?: boolean;
}

const { title, description, category, thumbnail, slug, featured = false } = Astro.props;

const categoryLabels: Record<string, string> = {
  video: 'Video Design',
  software: 'Software',
  motion: 'Motion Design',
  installation: 'Installation',
};
---

<article class:list={['portfolio-card', { featured }]}>
  <a href={`/portfolio/${slug}`} class="card-link">
    <div class="card-image">
      <img class="bg-blur" src={thumbnail} alt="" aria-hidden="true" loading="lazy" />
      <img class="main" src={thumbnail} alt={title} loading="lazy" />
      <div class="card-overlay">
        <span class="view-project">View Project</span>
      </div>
    </div>
    <div class="card-content">
      <span class="card-category">{categoryLabels[category] || category}</span>
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
    </div>
  </a>
</article>

<style>
  .portfolio-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }

  .portfolio-card:hover {
    border-color: var(--color-border);
  }

  .portfolio-card.featured {
    grid-column: span 2;
  }

  @media (max-width: 768px) {
    .portfolio-card.featured {
      grid-column: span 1;
    }
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-bg-alt);
  }

  .card-image .bg-blur {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(20px);
    transform: scale(1.1);
    opacity: 0.5;
  }

  .card-image .main {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform var(--transition-slow);
  }

  .portfolio-card:hover .card-image .main {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .portfolio-card:hover .card-overlay {
    opacity: 1;
  }

  .view-project {
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid white;
  }

  .card-content {
    padding: var(--space-lg);
  }

  .card-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-sm);
  }

  .card-title {
    font-size: 1.75rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .card-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
