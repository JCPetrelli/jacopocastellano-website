---
interface Repo {
  name: string;
  html_url: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  fork: boolean;
  archived: boolean;
  updated_at: string;
}

const username = 'JCPetrelli';
let repos: Repo[] = [];
let error = false;

try {
  const response = await fetch(
    `https://api.github.com/users/${username}/repos?sort=updated&per_page=100`,
    {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'Astro-Site'
      }
    }
  );

  if (response.ok) {
    const allRepos = await response.json() as Repo[];
    // Filter out forks and archived, sort by stars then by update date
    repos = allRepos
      .filter(repo => !repo.fork && !repo.archived)
      .sort((a, b) => b.stargazers_count - a.stargazers_count)
      .slice(0, 12);
  } else {
    error = true;
  }
} catch (e) {
  error = true;
}

const languageColors: Record<string, string> = {
  'Python': '#3572A5',
  'JavaScript': '#f1e05a',
  'TypeScript': '#3178c6',
  'HTML': '#e34c26',
  'CSS': '#563d7c',
  'Shell': '#89e051',
  'Swift': '#F05138',
  'Jupyter Notebook': '#DA5B0B',
};
---

<section class="github-repos">
  <h2>Open Source Projects</h2>
  <p class="section-intro">
    Selected repositories from my <a href={`https://github.com/${username}`} target="_blank" rel="noopener noreferrer">GitHub profile</a>.
  </p>

  {error ? (
    <p class="error-message">Unable to load repositories. Visit my <a href={`https://github.com/${username}`} target="_blank">GitHub profile</a> directly.</p>
  ) : (
    <div class="repos-grid">
      {repos.map(repo => (
        <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="repo-card">
          <h3 class="repo-name">{repo.name}</h3>
          {repo.description && (
            <p class="repo-description">{repo.description}</p>
          )}
          <div class="repo-meta">
            {repo.language && (
              <span class="repo-language">
                <span class="language-dot" style={`background-color: ${languageColors[repo.language] || '#858585'}`}></span>
                {repo.language}
              </span>
            )}
            {repo.stargazers_count > 0 && (
              <span class="repo-stars">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
                </svg>
                {repo.stargazers_count}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<style>
  .github-repos {
    margin-top: var(--space-2xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border-light);
  }

  .github-repos h2 {
    margin-bottom: var(--space-sm);
  }

  .section-intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .section-intro a {
    color: var(--color-text);
  }

  .repos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .repo-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    border: 1px solid var(--color-border-light);
    background: var(--color-bg);
    transition: border-color var(--transition-fast), background var(--transition-fast);
    text-decoration: none;
    color: inherit;
  }

  .repo-card:hover {
    border-color: var(--color-border);
    background: var(--color-bg-alt);
  }

  .repo-name {
    font-size: 1rem;
    font-family: var(--font-mono);
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .repo-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    flex-grow: 1;
    line-height: 1.5;
  }

  .repo-meta {
    display: flex;
    gap: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-subtle);
  }

  .repo-language {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .language-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .repo-stars {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .repo-stars svg {
    opacity: 0.7;
  }

  .error-message {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
