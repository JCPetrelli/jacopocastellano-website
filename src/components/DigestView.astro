---
// Shared renderer for a single AI Digest edition.
// Used by the live page (/ai-digest) and each archived edition
// (/ai-digest/archive/YYYY-MM-DD).
interface Source {
  name: string;
  url: string;
}
interface Point {
  headline: string;
  body: string;
  sources: Source[];
}
interface Props {
  date: Date;
  windowLabel: string;
  sources: number;
  articles: number;
  points: Point[];
  isLatest?: boolean;
}

const { date, windowLabel, sources, articles, points, isLatest = false } = Astro.props;

const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<section class="digest">
  <div class="container narrow">

    <header class="digest-hero">
      <span class="kicker">AI Digest{isLatest ? '' : ' · Archived'}</span>
      {isLatest ? (
        <h1>Everything you need to know about AI</h1>
        <p class="tagline">Bookmark this page. The most important things happening in AI, synthesized from dozens of sources into a two-minute read.</p>
      ) : (
        <h1>AI Digest</h1>
        <p class="tagline">An archived edition. For the current digest, see the <a href="/ai-digest">latest</a>.</p>
      )}
      <div class="hero-meta">
        {isLatest && <span class="badge">Updated every 48 hours</span>}
        <span class="meta-dim">
          {isLatest ? 'Last updated ' : 'Edition of '}{dateLabel} · {sources} sources · {articles} articles · {windowLabel} window
        </span>
        <span class="hero-links">
          {isLatest ? (
            <a href="/ai-digest/archive">View past digests →</a>
          ) : (
            <>
              <a href="/ai-digest">← Latest digest</a>
              <span class="sep">·</span>
              <a href="/ai-digest/archive">All past digests</a>
            </>
          )}
        </span>
      </div>
    </header>

    <ol class="digest-list">
      {points.map((point) => (
        <li class="digest-item">
          <p class="item-headline">{point.headline}</p>
          <p class="item-body">{point.body}</p>
          <p class="item-sources">
            <span class="sources-label">Sources</span>
            {point.sources.map((s, i) => (
              <>
                {i > 0 && <span class="sep">·</span>}
                <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
              </>
            ))}
          </p>
        </li>
      ))}
    </ol>

    <footer class="digest-foot">
      <p>Synthesized automatically from major AI and tech news feeds, deduplicated so each point reflects what multiple outlets are reporting. Links point to the original sources.</p>
    </footer>

  </div>
</section>

<style>
  .digest {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .narrow {
    max-width: var(--container-narrow);
  }

  /* ── Hero / banner ── */
  .digest-hero {
    text-align: center;
    padding-bottom: var(--space-xl);
    margin-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border-light);
  }

  .kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-md);
  }

  .digest-hero h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 var(--space-md) 0;
  }

  .tagline {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto var(--space-lg) auto;
  }

  .tagline a {
    color: var(--color-text);
    text-decoration: underline;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: var(--space-xs) var(--space-md);
  }

  .meta-dim {
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .hero-links {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .hero-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .hero-links a:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  /* ── List of points ── */
  .digest-list {
    list-style: none;
    counter-reset: digest;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .digest-item {
    counter-increment: digest;
    position: relative;
    padding: var(--space-lg);
    padding-left: calc(var(--space-lg) + 2.5rem);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
  }

  .digest-item::before {
    content: counter(digest);
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-text-subtle);
    width: 1.75rem;
    text-align: center;
  }

  .item-headline {
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--color-text);
    margin: 0 0 var(--space-sm) 0;
  }

  .item-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-md) 0;
  }

  .item-sources {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    margin: 0;
  }

  .sources-label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    margin-right: var(--space-xs);
  }

  .item-sources a {
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .item-sources a:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .sep {
    color: var(--color-text-subtle);
  }

  /* ── Footer note ── */
  .digest-foot {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border-light);
  }

  .digest-foot p {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-text-subtle);
    margin: 0;
  }

  @media (max-width: 600px) {
    .digest-item {
      padding-left: var(--space-lg);
    }
    .digest-item::before {
      position: static;
      display: block;
      text-align: left;
      margin-bottom: var(--space-xs);
    }
  }
</style>
