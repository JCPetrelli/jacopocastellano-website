---
interface Video {
  id: string;
  title: string;
  published: string;
  thumbnail: string;
}

const channelId = 'UCiVwuK0LOAPZWaXvhNjIB0g';
const channelUrl = `https://www.youtube.com/channel/${channelId}`;
let videos: Video[] = [];
let error = false;

try {
  const feedUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${channelId}`;
  const response = await fetch(feedUrl);

  if (response.ok) {
    const xml = await response.text();

    // Parse video entries from RSS feed
    const entryRegex = /<entry>([\s\S]*?)<\/entry>/g;
    const entries = xml.match(entryRegex) || [];

    videos = entries.slice(0, 8).map(entry => {
      const videoId = entry.match(/<yt:videoId>([^<]+)<\/yt:videoId>/)?.[1] || '';
      const title = entry.match(/<title>([^<]+)<\/title>/)?.[1] || '';
      const published = entry.match(/<published>([^<]+)<\/published>/)?.[1] || '';

      return {
        id: videoId,
        title: title,
        published: published,
        thumbnail: `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`
      };
    });
  } else {
    error = true;
  }
} catch (e) {
  error = true;
}

function formatDate(dateStr: string): string {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
  } catch {
    return '';
  }
}
---

<section class="youtube-videos">
  <h2>Video Work</h2>
  <p class="section-intro">
    Recent videos from my <a href={channelUrl} target="_blank" rel="noopener noreferrer">YouTube channel</a>.
  </p>

  {error ? (
    <p class="error-message">Unable to load videos. Visit my <a href={channelUrl} target="_blank">YouTube channel</a> directly.</p>
  ) : videos.length === 0 ? (
    <p class="error-message">No videos found. Visit my <a href={channelUrl} target="_blank">YouTube channel</a> directly.</p>
  ) : (
    <div class="videos-grid">
      {videos.map(video => (
        <a
          href={`https://www.youtube.com/watch?v=${video.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="video-card"
        >
          <div class="video-thumbnail">
            <img src={video.thumbnail} alt={video.title} loading="lazy" />
            <div class="play-overlay">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <div class="video-info">
            <h3 class="video-title">{video.title}</h3>
            <span class="video-date">{formatDate(video.published)}</span>
          </div>
        </a>
      ))}
    </div>
  )}
</section>

<style>
  .youtube-videos {
    margin-top: var(--space-2xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border-light);
  }

  .youtube-videos h2 {
    margin-bottom: var(--space-sm);
  }

  .section-intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .section-intro a {
    color: var(--color-text);
  }

  .videos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .video-card {
    text-decoration: none;
    color: inherit;
  }

  .video-thumbnail {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-alt);
    margin-bottom: var(--space-sm);
  }

  .video-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .video-card:hover .video-thumbnail img {
    transform: scale(1.05);
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .play-overlay svg {
    color: white;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .video-card:hover .play-overlay {
    opacity: 1;
  }

  .video-info {
    padding: 0 var(--space-xs);
  }

  .video-title {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .video-date {
    font-size: 0.75rem;
    color: var(--color-text-subtle);
  }

  .error-message {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
