---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const portfolioItems = await getCollection('portfolio');
const featuredProjects = portfolioItems
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = blogPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Senior Software Engineer & Video Designer">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-video-wrapper">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        poster="/videos/hero-bg-poster.jpg"
      >
        <source src="/videos/hero-bg.webm" type="video/webm" />
        <source src="/videos/hero-bg.mp4" type="video/mp4" />
      </video>
      <div class="hero-overlay"></div>
    </div>
    <button class="audio-toggle" id="audioToggle" aria-label="Toggle audio">
      <svg class="icon-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M11 5L6 9H2v6h4l5 4V5z"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      <svg class="icon-unmuted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M11 5L6 9H2v6h4l5 4V5z"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
        <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    </button>
    <div class="container">
      <div class="hero-content">
        <h1 class="hero-title">
          Senior Software Engineer<br />
          <span class="text-muted">&</span> Video Designer
        </h1>
        <p class="hero-description">
          Specializing in AI-driven development and real-time video design.
          Based in Berlin, working globally.
        </p>
        <div class="hero-actions">
          <a href="/portfolio" class="btn btn-primary">View Work</a>
          <a href="/contact" class="btn">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Highlighted Projects -->
  <section class="highlighted-projects">
    <div class="container">
      <header class="section-header">
        <h2>Current Ventures</h2>
      </header>

      <div class="highlight-grid">
        <a href="https://www.doppelganger.mov/" target="_blank" rel="noopener" class="highlight-card">
          <div class="highlight-content">
            <span class="highlight-tag">Audiovisual Duo</span>
            <h3 class="highlight-title">Doppelganger</h3>
            <p class="highlight-description">
              Berlin-based duo creating audiovisual performances and installations.
            </p>
            <span class="highlight-link">Visit doppelganger.mov <span class="arrow">&rarr;</span></span>
          </div>
        </a>

        <a href="https://www.bambooflags.com/" target="_blank" rel="noopener" class="highlight-card">
          <div class="highlight-content">
            <span class="highlight-tag">Automation & AI</span>
            <h3 class="highlight-title">Bamboo Flags</h3>
            <p class="highlight-description">
              Automation and AI solutions for growing companies. Web development, process optimization,
              and intelligent systems that help businesses scale efficiently.
            </p>
            <span class="highlight-link">Visit bambooflags.com <span class="arrow">&rarr;</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="featured">
    <div class="container">
      <header class="section-header">
        <h2>Featured Work</h2>
        <a href="/portfolio" class="section-link">View All Projects &rarr;</a>
      </header>

      <div class="portfolio-grid">
        {featuredProjects.map((project) => (
          <PortfolioCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            thumbnail={project.data.thumbnail}
            slug={project.id}
            featured={project.data.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="about-preview">
    <div class="container container-narrow">
      <h2>About Me</h2>
      <p class="about-text">
        10+ years in software engineering and video design. I build backend systems
        and create visuals for ballet and classical music productions.
      </p>
      <a href="/about" class="btn">Learn More</a>
    </div>
  </section>

  <!-- Recent Blog -->
  {recentPosts.length > 0 && (
    <section class="recent-posts">
      <div class="container">
        <header class="section-header">
          <h2>Recent Writing</h2>
          <a href="/blog" class="section-link">View All Posts &rarr;</a>
        </header>

        <div class="blog-grid grid grid-3">
          {recentPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              tags={post.data.tags}
              image={post.data.image}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: var(--space-2xl) 0;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-video-wrapper {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.35) 50%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .hero-content {
    position: relative;
    max-width: 720px;
  }

  .hero-title {
    margin-bottom: var(--space-lg);
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xl);
  }

  .section-header h2 {
    margin-bottom: 0;
  }

  .section-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .section-link:hover {
    color: var(--color-text);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-preview {
    text-align: center;
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  .about-text {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .audio-toggle {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .audio-toggle:hover {
    background: rgba(0, 0, 0, 0.6);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .audio-toggle svg {
    width: 20px;
    height: 20px;
  }

  .audio-toggle .icon-unmuted {
    display: none;
  }

  .audio-toggle.playing .icon-muted {
    display: none;
  }

  .audio-toggle.playing .icon-unmuted {
    display: block;
  }

  /* Highlighted Projects */
  .highlighted-projects {
    padding: var(--space-2xl) 0;
    background: var(--color-bg);
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 768px) {
    .highlight-grid {
      grid-template-columns: 1fr;
    }
  }

  .highlight-card {
    display: block;
    position: relative;
    padding: var(--space-xl);
    background: linear-gradient(135deg, var(--color-bg-alt) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid var(--color-border-light);
    text-decoration: none;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .highlight-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent, #888) 0%, transparent 100%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .highlight-card:hover {
    border-color: var(--color-border);
    transform: translateY(-2px);
  }

  .highlight-card:hover::before {
    opacity: 1;
  }

  .highlight-content {
    position: relative;
  }

  .highlight-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-md);
  }

  .highlight-title {
    font-size: 2rem;
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .highlight-description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .highlight-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .highlight-card:hover .highlight-link {
    color: var(--color-text);
  }

  .highlight-link .arrow {
    margin-left: var(--space-xs);
    transition: transform var(--transition-fast);
  }

  .highlight-card:hover .highlight-link .arrow {
    transform: translateX(4px);
  }
</style>

<script>
  const audioToggle = document.getElementById('audioToggle');
  const heroVideo = document.querySelector('.hero-video') as HTMLVideoElement;

  if (audioToggle && heroVideo) {
    audioToggle.addEventListener('click', () => {
      heroVideo.muted = !heroVideo.muted;
      audioToggle.classList.toggle('playing', !heroVideo.muted);
    });
  }
</script>
