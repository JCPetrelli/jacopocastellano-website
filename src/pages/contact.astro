---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch for collaborations, projects, or just to say hello.">
  <section class="contact-page">
    <div class="container container-narrow">
      <header class="page-header">
        <h1>Get in Touch</h1>
        <p class="page-description">
          Have a project in mind? Want to collaborate? Or just want to say hello?
          I'd love to hear from you.
        </p>
      </header>

      <form class="contact-form" action="https://formspree.io/f/meekknwy" method="POST">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="subject">Subject</label>
          <select id="subject" name="subject" required>
            <option value="">Select a topic</option>
            <option value="software">Software Engineering Project</option>
            <option value="video">Video Design Project</option>
            <option value="collaboration">Collaboration</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>

      <div class="contact-alternatives">
        <p class="text-muted">
          Want to talk with my digital assistant instead? Just write to
          <a href="mailto:piscubot@gmail.com">piscubot@gmail.com</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-top: var(--space-xl);
  }

  .page-header {
    margin-bottom: var(--space-xl);
  }

  .page-header h1 {
    margin-bottom: var(--space-md);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
  }

  .contact-form {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .form-group {
    margin-bottom: var(--space-lg);
  }

  label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  input,
  select,
  textarea {
    width: 100%;
    padding: var(--space-md);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: border-color var(--transition-fast);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }

  textarea {
    resize: vertical;
    min-height: 150px;
  }

  .contact-alternatives {
    text-align: center;
  }

  .contact-alternatives a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
